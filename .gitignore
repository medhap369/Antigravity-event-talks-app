# pyenv
#   For a library or package, you might want to ignore these files since the code is
#   intended to run in multiple environments; otherwise, check them in:
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if used in a cloud service, or to prevent conflicts, it may be ignored.
# Lockfile should be in version control, so we don't ignore it.

# poetry
#   Similar to Pipenv, poetry.lock should be in version control.

# pdm
#   Similar to Pipenv, pdm.lock should be in version control.

# virtualenv
venv/
ENV/
env/

